# Опційно: базові URL магазинів (без query). За замовчуванням — прямі https://florium.ua/ та https://agromarket.ua/
PUBLIC_FLORIUM_BASE_URL=https://florium.ua
PUBLIC_AGROMARKET_BASE_URL=https://agromarket.ua

