---
import { NAV_MAIN, SITE } from '../data/site';
---

<header class="header">
	<div class="container header__inner">
		<a class="brand" href="/" aria-label={`${SITE.name} — головна`}>
			<span class="brand__mark" aria-hidden="true"></span>
			<span class="brand__text">
				<span class="brand__name">{SITE.name}</span>
				<span class="brand__tag muted">Сад · Город · Ділянка</span>
			</span>
		</a>

		<nav class="nav" aria-label="Головна навігація">
			<ul class="nav__list">
				{
					NAV_MAIN.map((item) => (
						<li>
							<a href={item.href}>{item.label}</a>
						</li>
					))
				}
			</ul>
		</nav>
	</div>
</header>

<style>
	.header {
		position: sticky;
		top: 0;
		z-index: 40;
		backdrop-filter: blur(10px);
		background: color-mix(in oklab, var(--bg) 86%, white);
		border-bottom: 1px solid var(--line);
	}
	.header__inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 16px;
		padding: 14px 0;
	}
	.brand {
		display: flex;
		align-items: center;
		gap: 12px;
		text-decoration: none;
		color: inherit;
		min-width: 200px;
	}
	.brand__mark {
		width: 14px;
		height: 14px;
		border-radius: 5px;
		background: radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.65), transparent 40%),
			linear-gradient(145deg, var(--green-500), var(--green-900));
		box-shadow: 0 10px 22px rgba(31, 61, 43, 0.18);
	}
	.brand__text {
		display: grid;
		gap: 2px;
		line-height: 1.1;
	}
	.brand__name {
		font-weight: 800;
		letter-spacing: -0.02em;
	}
	.brand__tag {
		font-size: 12px;
	}
	.nav__list {
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: 10px 14px;
		padding: 0;
		margin: 0;
		justify-content: flex-end;
	}
	.nav a {
		font-size: 14px;
		font-weight: 650;
		text-decoration: none;
		padding: 8px 10px;
		border-radius: 10px;
	}
	.nav a:hover {
		background: rgba(63, 143, 90, 0.1);
	}
	@media (max-width: 920px) {
		.header__inner {
			flex-direction: column;
			align-items: flex-start;
		}
		.nav__list {
			justify-content: flex-start;
		}
	}
</style>
