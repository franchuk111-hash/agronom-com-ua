---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../data/site';
import { organizationSchema, websiteSchema, jsonLd } from '../lib/schema';

type Props = {
	title: string;
	description: string;
	canonicalPath: string;
	extraJsonLd?: readonly unknown[];
	ogType?: 'website' | 'article';
	/** ISO-8601, напр. 2026-04-13T08:00:00+03:00 */
	articlePublished?: string;
	articleModified?: string;
	robots?: string;
};

const {
	title,
	description,
	canonicalPath,
	extraJsonLd = [],
	ogType = 'website',
	articlePublished,
	articleModified,
	robots,
} = Astro.props as Props;
const canonicalUrl = new URL(canonicalPath, `https://${SITE.domain}/`).toString();
const ogImage = new URL('/og-default.svg', `https://${SITE.domain}/`).toString();

const baseLd = [organizationSchema(), websiteSchema(), ...extraJsonLd].map(jsonLd);
---

<!doctype html>
<html lang={SITE.lang}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="canonical" href={canonicalUrl} />
		<title>{title}</title>
		<meta name="description" content={description} />
		{robots ? <meta name="robots" content={robots} /> : null}
		<meta name="theme-color" content="#2f6a44" />

		<meta property="og:locale" content={SITE.locale} />
		<meta property="og:type" content={ogType} />
		<meta property="og:site_name" content={SITE.name} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={ogImage} />
		{
			ogType === 'article' && articlePublished ? (
				<meta property="article:published_time" content={articlePublished} />
			) : null
		}
		{ogType === 'article' && articleModified ? <meta property="article:modified_time" content={articleModified} /> : null}

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		{baseLd.map((s) => <script type="application/ld+json" set:html={s} />)}
	</head>
	<body>
		<a class="skip-link" href="#main">Перейти до основного вмісту</a>
		<Header />
		<main id="main">
			<slot />
		</main>
		<Footer />
	</body>
</html>
